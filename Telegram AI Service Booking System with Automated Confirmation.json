    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"bookingConfirmed\": {\n      \"type\": \"boolean\",\n      \"description\": \"Set true only when the user clearly says confirm/yes and all required details are collected.\"\n    },\n    \"customerName\": {\n      \"type\": \"string\",\n      \"description\": \"Full name of the customer\"\n    },\n    \"email\": {\n      \"type\": \"string\",\n      \"description\": \"Customer email address\"\n    },\n    \"product\": {\n      \"type\": \"string\",\n      \"description\": \"Selected product or service name (must match the sheet name exactly if possible)\"\n    },\n    \"itemType\": {\n      \"type\": \"string\",\n      \"description\": \"Either 'Product' or 'Service'. If Service Time > 0 then Service, else Product.\"\n    },\n    \"quantity\": {\n      \"type\": \"number\",\n      \"description\": \"Only for Product orders. Must be 1 or more. For Service set to 1.\"\n    },\n    \"dateTime\": {\n      \"type\": \"string\",\n      \"description\": \"For Service: required preferred date/time. For Product: put 'N/A' if user did not provide delivery time.\"\n    },\n    \"conversationalMessage\": {\n      \"type\": \"string\",\n      \"description\": \"Friendly response message to send to the customer\"\n    }\n  }\n}"
      },
      "id": "67a03582-e84d-48c4-bab9-659fd3cb699c",
