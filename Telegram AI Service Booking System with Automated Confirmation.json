    {
      "parameters": {
        "jsCode": "// Get the structured output from AI Agent\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json.output || item.json;\n\n  const conversationalMessage =\n    data.conversationalMessage ||\n    \"I'm here to help you book our services or order products. What do you need?\";\n\n  const bookingConfirmed = data.bookingConfirmed === true;\n\n  if (bookingConfirmed) {\n    results.push({\n      json: {\n        customerName: data.customerName || \"\",\n        email: data.email || \"\",\n        product: data.product || \"\",\n        itemType: data.itemType || \"\",\n        quantity: data.quantity || 1,\n        dateTime: data.dateTime || \"\",\n        bookingConfirmed: true,\n        output: conversationalMessage\n      }\n    });\n  } else {\n    results.push({\n      json: {\n        output: conversationalMessage,\n        bookingConfirmed: false\n      }\n    });\n  }\n}\n\nreturn results;"
      },
      "id": "52c22bca-a504-4f4b-9e82-fc113c893b59",
      "name": "Parse Booking Data",
      "type": "n8n-nodes-base.code",
